{
  "_comment_a2k_basics": "Snippet à fusionner dans <repo>/.claude/settings.json — sections hooks + permissions.deny essentielles. NE PAS écraser les permissions.allow projet-spécifiques. Cf. ~/.claude/templates/a2k-basics/README.md",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/auto-approve-worktree.ps1",
            "timeout": 60
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/worktree-create.ps1",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git push -f *)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push --no-verify *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git commit --no-verify *)",
      "Bash(git commit --no-verify)",
      "Bash(git commit --no-gpg-sign *)",
      "Bash(git commit --no-gpg-sign)",
      "Bash(git commit -c commit.gpgsign=false *)",
      "Bash(git -c commit.gpgsign=false *)",
      "Bash(git commit --amend *)",
      "Bash(git commit --amend)",
      "Bash(git rebase -i *)",
      "Bash(git rebase --interactive *)",
      "Bash(git config user.email *)",
      "Bash(git config user.name *)",
      "Bash(git config --global *)",
      "Bash(git filter-branch *)",
      "Bash(git filter-branch)",
      "Bash(git reflog expire *)",
      "Bash(git reflog delete *)",
      "Bash(git update-ref -d *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf C:/)",
      "Bash(rm -rf C:/*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf .git)",
      "Bash(rm -rf .git/*)",
      "Bash(rm -rf .git/**)",
      "Bash(rm -rf .claude)",
      "Bash(rm -rf .claude/*)",
      "Bash(rm -rf .claude/**)",
      "Edit(.claude/settings.json)",
      "Edit(.claude/hooks/**)",
      "Write(.claude/settings.json)",
      "Write(.claude/hooks/**)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(sudo *)",
      "Bash(su -)",
      "Bash(su *)"
    ]
  }
}
